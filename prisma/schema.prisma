generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  productJson Json     // ProductInput
  analysisJson Json?   // ProductAnalysis
  segmentJson Json     // Segment
  status      String   @default("draft") // draft|analyzing|generating|review|approved|sent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages  Message[]
  sequences Sequence[]
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  platformId   String?
  platform     String?  // twitter|connpass|line|did-event
  attributesJson Json   // ContactAttributes
  behaviorsJson  Json   // ContactBehavior[]
  createdAt    DateTime @default(now())

  // ─── チャネル到達情報 ───
  email              String?
  lineUserId         String?
  messengerPsid      String?
  preferredChannel   String?  // mail|line|messenger
  lineLinkedAt       DateTime?
  messengerLastInboundAt DateTime?
  optOutEmail        Boolean  @default(false)
  optOutLine         Boolean  @default(false)
  optOutMessenger    Boolean  @default(false)

  tagsJson   Json?    // string[] — 動的タグ（interests等）

  messages   Message[]
  deliveries Delivery[]
  sequences  Sequence[]
  actionLogs ActionLog[]
}

model Message {
  id            String   @id @default(cuid())
  campaignId    String
  contactId     String
  variantsJson  Json     // MessageVariant[]
  approvedIndex Int?
  status        String   @default("draft") // draft|approved|sent|delivered|replied
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  // ─── チャネル関連 ───
  channel          String?  // mail|line|messenger
  providerMessageId String?
  deliveryStatus   String?  // queued|sent|delivered|failed|bounced|rejected
  idempotencyKey   String?  @unique
  approvedBy       String?
  approvedAt       DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])

  results    OutreachResult[]
  deliveries Delivery[]
}

model OutreachResult {
  id           String   @id @default(cuid())
  messageId    String
  outcome      String   // no-response|opened|replied|converted
  replySnippet String?
  createdAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
}

model Delivery {
  id               String   @id @default(cuid())
  messageId        String
  contactId        String
  campaignId       String
  channel          String   // mail|line|messenger
  idempotencyKey   String   @unique
  providerMessageId String?
  status           String   @default("queued") // queued|sent|delivered|failed|bounced|rejected
  error            String?
  attemptCount     Int      @default(0)
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  message Message  @relation(fields: [messageId], references: [id])
  contact Contact  @relation(fields: [contactId], references: [id])

  @@index([campaignId, contactId, channel])
  @@index([idempotencyKey])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // approve|reject|channel_select|message_edit|queue_submit|send_success|send_failure
  campaignId  String
  targetId    String?
  contactId   String?
  channel     String?
  performedBy String
  detailsJson Json?
  createdAt   DateTime @default(now())

  @@index([campaignId])
  @@index([action])
}

model PromptIteration {
  id              String   @id @default(cuid())
  version         Int      @unique
  prompt          String
  avgOutcomeScore Float
  changeNote      String
  createdAt       DateTime @default(now())
}

// ─── シーケンス配信（ケイデンス機能） ───

model Sequence {
  id          String   @id @default(cuid())
  campaignId  String
  contactId   String
  status      String   @default("draft") // draft|approved|active|paused|completed|cancelled|responded
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])
  steps    SequenceStep[]
  actionLogs ActionLog[]

  @@index([campaignId])
  @@index([contactId])
  @@index([status])
}

model SequenceStep {
  id             String    @id @default(cuid())
  sequenceId     String
  stepOrder      Int       // 0-based: 0=初回, 1=フォロー, 2=クロージング...
  delayHours     Int       @default(0) // 前のステップからの遅延時間
  channel        String    // mail|line|messenger
  body           String    // メッセージ本文
  angle          String    // 使用した切り口
  subject        String?   // mail用件名
  status         String    @default("pending") // pending|scheduled|sent|delivered|cancelled|failed
  scheduledAt    DateTime?
  sentAt         DateTime?
  idempotencyKey String?   @unique
  jobId          String?   // BullMQ等のジョブID
  variantsJson   Json?     // A/Bテスト用の代替案 MessageVariant[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sequence      Sequence       @relation(fields: [sequenceId], references: [id])
  trackingLinks TrackingLink[]

  @@unique([sequenceId, stepOrder])
  @@index([status])
  @@index([scheduledAt])
}

model TrackingLink {
  id              String    @id @default(cuid())
  sequenceStepId  String
  originalUrl     String
  trackingToken   String    @unique
  clickedAt       DateTime?
  clickCount      Int       @default(0)
  createdAt       DateTime  @default(now())

  sequenceStep SequenceStep @relation(fields: [sequenceStepId], references: [id])

  @@index([trackingToken])
}

model ActionLog {
  id          String   @id @default(cuid())
  contactId   String
  sequenceId  String?
  type        String   // reply|conversion|link_click|opt_out|tag_added
  payloadJson Json?    // アクション固有のデータ
  createdAt   DateTime @default(now())

  contact  Contact   @relation(fields: [contactId], references: [id])
  sequence Sequence? @relation(fields: [sequenceId], references: [id])

  @@index([contactId])
  @@index([sequenceId])
  @@index([type])
}
